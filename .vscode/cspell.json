{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "useGitignore": true,
  "ignorePaths": [
    "build",
    ".svelte-kit",
    ".wrangler",
    "node_modules",
    "package-lock.json",
    "playwright-report",
    "test-results",
    "docs/superpowers"
  ],
  "files": ["**/*.{css,html,js,json,md,svelte,ts,txt,yml,yaml}"],
  "ignoreRegExpList": ["/https?:\\/\\/\\S+/g", "/\\b[a-f0-9]{7,}\\b/g"],
  "words": [
    "Archi",
    "centerer",
    "embiggen",
    "favicons",
    "fetchpriority",
    "FOIT",
    "geolocation",
    "haspopup",
    "HCII",
    "Helmbrecht",
    "imagetools",
    "jank",
    "Kidfund",
    "labelledby",
    "lightbox",
    "Lightboxes",
    "loooooooong",
    "Motiv",
    "mrh",
    "necolas",
    "networkidle",
    "noopener",
    "noreferrer",
    "nosniff",
    "parque",
    "pelago",
    "preconnects",
    "prerender",
    "scannability",
    "Sniglet",
    "srcsets",
    "subblock",
    "Waggler",
    "Woohoo",
    "xorshift"
  ]
}
